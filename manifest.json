{
  "manifest_version": 3,
  "name": "Disappointed Floatplane Queue",
  "version": "1.0.0",
  "description": "Adds a watch queue (playlist) with autoplay to floatplane.com.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.floatplane.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.floatplane.com/*"],
      "js": [
        "js/storage.js",
        "js/state.js",
        "js/utils.js",
        "js/panel.js",
        "js/settings.js",
        "js/render.js",
        "js/queue-actions.js",
        "js/tile-buttons.js",
        "js/page-sync.js",
        "js/autoplay.js",
        "js/main.js"
      ],
      "css": ["assets/content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/cog.svg"],
      "matches": ["*://*.floatplane.com/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "disappointed-floatplane-queue@disappointed.moose"
    }
  }
}
